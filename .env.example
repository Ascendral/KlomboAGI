# KlomboAGI Environment Configuration
# Copy this to .env and adjust paths as needed

KLOMBOAGI_RUNTIME_ROOT=$HOME/KlomboAGI/runtime
KLOMBOAGI_LONG_TERM_ROOT=$HOME/KlomboAGI/long-term
KLOMBOAGI_WORKSPACE_ROOT=$HOME/KlomboAGI/workspace

# LLM provider (optional — system works without LLM)
# KLOMBOAGI_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-key-here
# KLOMBOAGI_LLM_ENABLED=false
