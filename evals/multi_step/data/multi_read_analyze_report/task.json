      "input": "previous_result"
    },
    {
      "action": "find_max",
      "column": "revenue"
    }
  ],
  "inputs": {
    "csv_data": "month,revenue\nJan,1000\nFeb,1500\nMar,1200\nApr,2000\nMay,1800"
  },
  "expected": {
    "month": "Apr",
    "revenue": 2000
  },
  "scorer": "exact_match"
}