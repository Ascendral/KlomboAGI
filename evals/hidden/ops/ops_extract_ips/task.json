{
  "id": "ops_extract_ips",
  "domain": "ops",
  "description": "Extract all unique IP addresses from this log",
  "inputs": {
    "log": "192.168.1.1 - GET /api\n10.0.0.5 - POST /data\n192.168.1.1 - GET /health\n10.0.0.5 - GET /api\n172.16.0.1 - DELETE /old"
  },
  "expected": [
    "10.0.0.5",
    "172.16.0.1",
    "192.168.1.1"
  ],
  "scorer": "exact_match"
}