    "test_domain": "research",
    "test_task": {
      "id": "test_unique_authors",
      "description": "Return unique values from this list, preserving order",
      "inputs": {
        "items": [
          "Smith",
          "Jones",
          "Smith",
          "Williams",
          "Jones",
          "Brown"
        ]
      },
      "expected": [
        "Smith",
        "Jones",
        "Williams",
        "Brown"
      ],
      "scorer": "exact_match"
    },
    "transfer_type": "identical_structure",
    "description": "Deduplication transfers directly \u2014 same structure, different content"
  }
